rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && (
          request.auth.token.superAdmin == true
          || request.auth.token.role == 'super_admin'
        );
    }

    function isBusinessOwner() {
      return isSignedIn()
        && request.auth.token.businessId is string
        && (
          request.auth.token.role == 'owner'
          || request.auth.token.role == 'admin'
        );
    }

    function signedInUserDocExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDocData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userIsOwnerRole() {
      return signedInUserDocExists()
        && userDocData().role in [
          'owner',
          'admin',
          'business_owner',
          'salon_owner'
        ];
    }

    function userOwnsBusiness(businessId) {
      return userIsOwnerRole()
        && userDocData().businessId == businessId;
    }

    function ownsBusiness(businessId) {
      return isBusinessOwner() && request.auth.token.businessId == businessId;
    }

    // Login gate: each user may read only their own super_admins document.
    match /super_admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // Business owners read their workspace; super admins read all.
    match /businesses/{businessId} {
      allow read: if isSuperAdmin()
        || ownsBusiness(businessId)
        || (signedInUserDocExists() && resource.data.ownerUid == request.auth.uid);
      allow create, update, delete: if false;
    }

    function isBusinessStaff() {
      return isSignedIn()
        && request.auth.token.businessId is string
        && request.auth.token.role == 'staff';
    }

    function ownsStaffInspection() {
      return isBusinessStaff()
        && resource.data.businessId == request.auth.token.businessId
        && resource.data.assignedTo is map
        && resource.data.assignedTo.uid == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    // Booking intake attempts: write-only audit log from server; admins/owners read.
    match /booking_intake_attempts/{attemptId} {
      allow read: if isSuperAdmin()
        || (isBusinessOwner()
            && resource.data.businessId == request.auth.token.businessId);
      allow create, update, delete: if false;
    }

    match /service_templates/{templateId} {
      allow read: if isSuperAdmin() || (isBusinessOwner() && resource.data.isActive == true);
      allow create, update, delete: if false;
    }

    match /services/{serviceId} {
      allow read: if isSuperAdmin() || ownsBusiness(resource.data.businessId);
      allow create, update, delete: if false;
    }

    function ownsBusinessNotification() {
      return (isBusinessOwner()
          && resource.data.businessId == request.auth.token.businessId)
        || userOwnsBusiness(resource.data.businessId);
    }

    function notificationReadOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /business_notifications/{notificationId} {
      allow read: if isSuperAdmin() || ownsBusinessNotification();
      allow update: if isSuperAdmin()
        || (ownsBusinessNotification() && notificationReadOnlyUpdate());
      allow delete: if isSuperAdmin() || ownsBusinessNotification();
      allow create: if false;
    }

    function ownsCustomerNotification() {
      return isSignedIn()
        && (
          resource.data.customerId == request.auth.uid
          || (
            request.auth.token.email is string
            && resource.data.customerEmail == request.auth.token.email
          )
        );
    }

    match /customer_notifications/{notificationId} {
      allow read: if isSuperAdmin() || ownsCustomerNotification();
      allow update: if isSuperAdmin()
        || (ownsCustomerNotification() && notificationReadOnlyUpdate());
      allow delete: if isSuperAdmin() || ownsCustomerNotification();
      allow create: if false;
    }

    function ownsCustomerInspection() {
      return isSignedIn()
        && (
          resource.data.customerId == request.auth.uid
          || (
            request.auth.token.email is string
            && resource.data.customer.email == request.auth.token.email
          )
        );
    }

    match /inspection_requests/{requestId} {
      allow read: if isSuperAdmin()
        || (isBusinessOwner()
            && resource.data.businessId == request.auth.token.businessId)
        || userOwnsBusiness(resource.data.businessId)
        || ownsStaffInspection()
        || ownsCustomerInspection();
      allow create, update, delete: if false;
    }

    function ownsStaffBooking() {
      return isBusinessStaff()
        && resource.data.businessId == request.auth.token.businessId
        && resource.data.assignedTo is map
        && resource.data.assignedTo.uid == request.auth.uid;
    }

    function ownsAssignedTradeBooking() {
      return isSignedIn()
        && resource.data.assignedTo is map
        && resource.data.assignedTo.uid == request.auth.uid;
    }

    function ownsCustomerBooking() {
      return isSignedIn()
        && (
          resource.data.customerId == request.auth.uid
          || (
            request.auth.token.email is string
            && resource.data.customer is map
            && resource.data.customer.email == request.auth.token.email
          )
        );
    }

    function ownsSalonBooking() {
      return isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    function canReadTradeBooking() {
      return resource.data.businessId is string
        && (
          (isBusinessOwner()
              && resource.data.businessId == request.auth.token.businessId)
          || userOwnsBusiness(resource.data.businessId)
          || ownsStaffBooking()
          || ownsAssignedTradeBooking()
          || ownsCustomerBooking()
          || (isSignedIn()
              && resource.data.ownerUid == request.auth.uid)
        );
    }

    // Trade job bookings (from inspection visits) + legacy salon bookings (ownerUid).
    match /bookings/{bookingId} {
      allow read: if isSuperAdmin()
        || ownsSalonBooking()
        || canReadTradeBooking();
      allow create, update, delete: if false;
    }

    match /quotations/{quotationId} {
      allow read: if isSuperAdmin()
        || (isBusinessOwner()
            && resource.data.businessId == request.auth.token.businessId)
        || userOwnsBusiness(resource.data.businessId);
      allow create, update, delete: if false;
    }

    function isCallCenterAgent() {
      return isSignedIn() && request.auth.token.role == 'call_center';
    }

    match /conversations/{conversationId} {
      allow read: if isSuperAdmin()
        || isCallCenterAgent()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSuperAdmin()
          || isCallCenterAgent()
          || (
            isSignedIn()
            && get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId
              == request.auth.uid
          );
        allow create, update, delete: if false;
      }
    }

    match /cc_direct_chats/{chatId} {
      allow read: if isSuperAdmin()
        || (isSignedIn() && request.auth.uid in resource.data.participantIds);
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSuperAdmin()
          || (
            isSignedIn()
            && request.auth.uid in get(/databases/$(database)/documents/cc_direct_chats/$(chatId)).data.participantIds
          );
        allow create, update, delete: if false;
      }
    }

    match /call_center_agents/{uid} {
      allow read: if isSuperAdmin()
        || (isSignedIn() && request.auth.uid == uid);
      allow create, update, delete: if false;
    }

    // Super admins can access remaining collections in the admin portal.
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
